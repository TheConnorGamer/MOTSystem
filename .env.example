# Database (Neon PostgreSQL — free at https://console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Redis (optional — used for token/cache and reminder worker)
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# DVSA MOT History API — https://documentation.history.mot.api.gov.uk/
DVSA_CLIENT_ID=""
DVSA_CLIENT_SECRET=""
DVSA_API_KEY=""
DVSA_SCOPE="https://tapi.dvsa.gov.uk/.default"
DVSA_TOKEN_URL="https://login.microsoftonline.com/{tenantId}/oauth2/v2.0/token"
DVSA_API_BASE="https://history.mot.api.gov.uk"

# Paid lookups (DVLA ~2p, RegCheck, RapidAPI) — keep false for free-only mode
PAID_LOOKUPS_ENABLED="false"

# DVLA Vehicle Enquiry Service (paid fallback — requires PAID_LOOKUPS_ENABLED=true)
DVLA_API_KEY=""
DVLA_VES_ENABLED="false"

# RapidAPI fallbacks (paid — requires PAID_LOOKUPS_ENABLED=true)
RAPIDAPI_KEY=""
RAPIDAPI_ENABLED="false"
RAPIDAPI_HOST="uk-vehicle-data1.p.rapidapi.com"
RAPIDAPI_PATH="/cartax.api.v1.Public/GetInitialReport"

# RegCheck (optional fallback — paid per lookup)
REGCHECK_ENABLED="false"
REGCHECK_USERNAME=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Stripe (optional)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""

# App
APP_URL="http://localhost:3000"
ADMIN_EMAIL="admin@example.com"

# Vercel Cron — daily reminder job (generate a long random string)
CRON_SECRET="generate-a-long-random-secret"
